# .env.example  — Copy to .env and fill in your real values
# Never commit .env to version control!

# ── App ────────────────────────────────────────────────
APP_NAME="Blog Empire"
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000

# ── Database (Nhost PostgreSQL) ────────────────────────────────────────────
# Get this from: Nhost dashboard → your project → Database → Connection tab
DATABASE_URL=URL

# ── Groq ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b

# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_admin_chat_id

# ── Dev.to ─────────────────────────────────────────────
DEVTO_API_KEY=your_devto_api_key



# ── Hashnode ───────────────────────────────────────────
HASHNODE_API_TOKEN=your_hashnode_api_token

HASHNODE_PUBLICATION_ID=your_hashnode_publication_id

# ── SEO Thresholds (optional, defaults shown) ──────────
SEO_THRESHOLD_VIEWS=100
SEO_THRESHOLD_SCORE=50.0
MAX_REVISIONS=3
